<?xml version='1.0' encoding='UTF-8'?>
<!-- Test case for a merger tree (read from file) containing an equal-mass isolated-versus-subhalo tie, with           -->
<!-- [alwaysPromoteMostMassive]=true:                                                                                  -->
<!--                                                                                                                   -->
<!--   z=1.0:   40 [isolated]   41 [subhalo of 40]   42 [isolated]                                                     -->
<!--             |                \                   /                                                                -->
<!--   z=0.5:   50 [isolated]     51 [isolated] <===+                                                                  -->
<!--             |                 |                                                                                   -->
<!--   z=0.0:   60 [isolated]     61 [isolated]                                                                        -->
<!--                                                                                                                   -->
<!-- Subhalo 41 and isolated halo 42 have precisely equal masses, and both descend into node 51. With                  -->
<!-- [alwaysPromoteMostMassive]=true the most senior progenitor is promoted even if it is a subhalo - but in the       -->
<!-- seniority ordering isolated halos outrank subhalos of precisely equal mass, so node 42 must remain the primary    -->
<!-- progenitor and node 41 must not be promoted. Since satellite merging is disabled here, node 41 must appear as a   -->
<!-- satellite at the final output time (and node 42 must not).                                                        -->
<!--                                                                                                                   -->
<!-- The input tree file is generated by testSuite/test-merger-tree-read-ties.py.                                      -->
<parameters>
  <formatVersion>2</formatVersion>

  <mergerTreeConstructor value="read">
    <fileNames value="testSuite/outputs/mergerTreeReadTieIsolatedPriority_in.hdf5"/>
    <presetPositions value="false"/>
    <presetOrbits value="false"/>
    <presetMergerTimes value="false"/>
    <presetMergerNodes value="false"/>
    <presetSubhaloMasses value="false"/>
    <presetSubhaloIndices value="false"/>
    <presetAngularMomenta value="false"/>
    <presetScaleRadii value="false"/>
    <alwaysPromoteMostMassive value="true"/>
  </mergerTreeConstructor>
  <mergerTreeEvolver value="standard">
    <allTreesExistAtFinalTime value="false"/>
  </mergerTreeEvolver>

  <!-- Validate the structural invariants of the constructed trees. -->
  <mergerTreeOperator value="validateStructure"/>

  <componentSatellite value="preset"/>
  <cosmologyParameters value="simple">
    <HubbleConstant value="70.0"/>
    <OmegaMatter value="0.3"/>
    <OmegaDarkEnergy value="0.7"/>
    <OmegaBaryon value="0.04"/>
  </cosmologyParameters>

  <cosmologicalMassVariance value="filteredPower">
    <sigma_8 value="0.93"/>
  </cosmologicalMassVariance>

  <hotHaloRamPressureStripping value="virialRadius"/>
  <hotHaloOutflowStripping value="zero"/>
  <componentHotHalo value="standard"/>

  <!-- Halo scale radii and concentrations -->
  <darkMatterProfileScaleRadius value="concentrationLimiter">
    <concentrationMinimum value="  4.0"/>
    <concentrationMaximum value="100.0"/>
    <darkMatterProfileScaleRadius value="concentration"/>
  </darkMatterProfileScaleRadius>

  <!-- Node evolution and physics -->
  <nodeOperator value="multi">
    <!-- Cosmological epoch -->
    <nodeOperator value="cosmicTime"/>
    <!-- DMO evolution -->
    <nodeOperator value="DMOInterpolate"/>
    <!-- Halo concentrations -->
    <nodeOperator value="darkMatterProfileScaleSet"/>
    <nodeOperator value="darkMatterProfileScaleInterpolate"/>
    <!-- Halo spins -->
    <nodeOperator value="haloAngularMomentumRandom">
      <factorReset value="2.0"/>
    </nodeOperator>
    <nodeOperator value="haloAngularMomentumInterpolate"/>
    <!-- Star formation -->
    <nodeOperator value="starFormationDisks"/>
    <nodeOperator value="starFormationSpheroids"/>
    <!--Stellar feedback outflows-->
    <nodeOperator value="stellarFeedbackDisks">
      <stellarFeedbackOutflows value="rateLimit">
        <timescaleOutflowFractionalMinimum value="0.001"/>
        <stellarFeedbackOutflows value="powerLaw">
          <velocityCharacteristic value="250.0"/>
          <exponent value="3.5"/>
        </stellarFeedbackOutflows>
      </stellarFeedbackOutflows>
    </nodeOperator>
    <nodeOperator value="stellarFeedbackSpheroids">
      <stellarFeedbackOutflows value="rateLimit">
        <timescaleOutflowFractionalMinimum value="0.001"/>
        <stellarFeedbackOutflows value="powerLaw">
          <velocityCharacteristic value="250.0"/>
          <exponent value="3.5"/>
        </stellarFeedbackOutflows>
      </stellarFeedbackOutflows>
    </nodeOperator>
    <nodeOperator value="satelliteOrphanize"/>
    <!-- CGM physics -->
    <nodeOperator value="CGMAccretion">
      <allowNegativeCGMMass value="true"/>
      <angularMomentumAlwaysGrows value="false"/>
    </nodeOperator>
    <nodeOperator value="CGMOutflowReincorporation">
      <includeSatellites value="true"/>
    </nodeOperator>
    <nodeOperator value="CGMCoolingHeating">
      <component value="disk"/>
      <coolingFrom value="currentNode"/>
      <excessHeatDrivesOutflow value="true"/>
      <rateMaximumExpulsion value="1.0"/>
    </nodeOperator>
    <nodeOperator value="CGMOuterRadiusRamPressureStripping"/>
  </nodeOperator>

  <outputFileName value="testSuite/outputs/mergerTreeReadTieIsolatedPriority.hdf5"/>

</parameters>
