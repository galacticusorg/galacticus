<?xml version='1.0' encoding='UTF-8'?>
<!-- Compute spin distribution functions -->

<parameters>
  <formatVersion>2</formatVersion>
  <lastModified revision="23263e8c1dfc569099e2c1fbdedbc04ed6446e59" time="2026-05-18T15:53:57"/>


  <task value="NBodyAnalyze"/>

  <nbodyImporter value="merge">
  </nbodyImporter>

  <nbodyOperator value="sequence">
    <nbodyOperator value="addAttributes">
      <names  value="massParticle"/>
      <values value="1.0e9       "/>
    </nbodyOperator>
    <nbodyOperator value="filterProperties"   >
      <propertyNames value="virialRatio timeSinceFormationFractional"/>
      <rangeLow      value="0.5         1.25                        "/>
      <rangeHigh     value="1.5         +infinity                   "/>
    </nbodyOperator>
    <nbodyOperator value="spinDistributionFunction">
      <description                       value=""       />
      <simulationReference               value=""       />
      <simulationURL                     value=""       />
      <massMinimum                       value="1.0e+12"/>
      <massMaximum                       value="1.0e+30"/>
      <massCountPerDecade                value="2"      />
      <spinMinimum                       value="1.0e-03"/>
      <spinMaximum                       value="1.0e+00"/>
      <spinCountPerDecade                value="5"      />
    </nbodyOperator>
  </nbodyOperator>
  
</parameters>
