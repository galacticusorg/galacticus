<?xml version='1.0' encoding='UTF-8'?>
<parameters>
  <lastModified revision="23263e8c1dfc569099e2c1fbdedbc04ed6446e59" time="2026-05-18T15:53:57"/>
  <formatVersion>2</formatVersion>
  <version>0.9.4</version>

  <!-- Merger tree building options -->
  <mergerTreeConstructor value="build"/>
  <mergerTreeBuilder value="cole2000">
    <accretionLimit        value="0.01"  />
    <mergeProbability      value="0.10"  />
    <branchIntervalStep    value="true"  />
    <redshiftMaximum       value="10.0"  />
    <!-- Relaxed from 1.0e-5: the tight tolerance trips "branch is making no progress"
         in cole2000 during first-run adaptive tabulation (e.g. sigma(M) tables
         extending mid-build). 1.0e-4 avoids the warm-up aborts with negligible impact
         on tree accuracy (a full 12.5k-tree progenitor run also completes cleanly at
         1.0e-3 if more margin is wanted). -->
    <toleranceTimeEarliest value="1.0e-4"/>
  </mergerTreeBuilder>
  <mergerTreeBranchingProbability value="PCHPlus">
    <!-- Best fit values from PCH -->
    <G0                 value="+0.57"  />
    <gamma1             value="+0.38"  />
    <gamma2             value="-0.01"  />
    <gamma3             value="+0.00"  />
    <accuracyFirstOrder value="+0.1000"/>
    <cdmAssumptions     value="true"   />
  </mergerTreeBranchingProbability>

  <!-- Subsampling merger of merger tree branches -->
  <mergerTreeBuildController value="subsample">
    <fractionMassThreshold      value="0.1"/>
    <subsamplingRateAtThreshold value="1.0"/>
    <exponent                   value="1.0"/>
  </mergerTreeBuildController>

  <!-- Merger tree evolution -->
  <mergerTreeEvolver value="standard">
    <timestepHostAbsolute value="1.0"/>
    <timestepHostRelative value="0.1"/>
  </mergerTreeEvolver>
  <mergerTreeNodeEvolver value="standard">
    <odeToleranceAbsolute value="0.01"/>
    <odeToleranceRelative value="0.01"/>
  </mergerTreeNodeEvolver>
  <nodeOperator value="multi">
    <!-- Cosmological epoch -->
    <nodeOperator value="cosmicTime"/>
    <!-- DMO evolution -->
    <nodeOperator value="DMOInterpolate"/>
    <!-- Subhalo hierarchy -->
    <nodeOperator value="hierarchy"/>
  </nodeOperator>

  <!-- Component selection -->
  <componentBasic              value="standard" />
  <componentBlackHole          value="null"     />
  <componentDarkMatterProfile  value="scaleFree"/>
  <componentDisk               value="null"     />
  <componentHotHalo            value="null"     />
  <componentSatellite          value="null"     />
  <componentSpheroid           value="null"     />
  <componentSpin               value="null"     />

  <!-- Nullify irrelevant classes -->
  <hotHaloMassDistribution value="null"/>

  <!-- Substructure hierarchy options -->
  <mergerTreeNodeMerger value="singleLevelHierarchy"/>

  <!-- Dark matter halo structure options - allows use of simplest darkMatterProfile component -->
  <darkMatterProfileDMO value="isothermal"/>

  <!-- Disable baryonic physics -->
  <mergerRemnantSize value="null"/>
  
</parameters>
