@Article{	  eisenstein_baryonic_1998,
  title		= {Baryonic {Features} in the {Matter} {Transfer}
		  {Function}},
  volume	= {496},
  issn		= {0004-637X},
  url		= {https://ui.adsabs.harvard.edu/abs/1998ApJ...496..605E},
  doi		= {10.1086/305424},
  abstract	= {We provide scaling relations and fitting formulae for
		  adiabatic cold dark matter cosmologies that account for all
		  baryon effects in the matter transfer function to better
		  than 10\% in the large-scale structure regime. They are
		  based upon a physically well-motivated separation of the
		  effects of acoustic oscillations, Compton drag, velocity
		  overshoot, baryon infall, adiabatic damping, Silk damping,
		  and cold dark matter growth suppression. We also find a
		  simpler, more accurate, and better motivated form for the
		  zero-baryon transfer function than previous works. These
		  descriptions are employed to quantify the amplitude and
		  location of baryonic features in linear theory. While
		  baryonic oscillations are prominent if the baryon fraction
		  Ωb/Ω0 {\textgreater}{\textasciitilde} Ω0h2 + 0.2, the
		  main effect in more conventional cosmologies is a sharp
		  suppression in the transfer function below the sound
		  horizon. We provide a simple but accurate description of
		  this effect and stress that it is not well approximated by
		  a change in the shape parameter Γ.},
  urldate	= {2024-04-22},
  journal	= {The Astrophysical Journal},
  author	= {Eisenstein, Daniel J. and Hu, Wayne},
  month		= mar,
  year		= {1998},
  note		= {Publisher: IOP ADS Bibcode: 1998ApJ...496..605E},
  keywords	= {Astrophysics, Cosmology: Dark Matter, COSMOLOGY: DARK
		  MATTER, Cosmology: Large-Scale Structure of Universe,
		  COSMOLOGY: LARGE-SCALE STRUCTURE OF UNIVERSE, Cosmology:
		  Theory, COSMOLOGY: THEORY},
  pages		= {605--614}
}

