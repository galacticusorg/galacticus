@Article{	  portinari_galactic_1998,
  title		= {Galactic chemical enrichment with new metallicity
		  dependent stellar yields},
  volume	= {334},
  issn		= {0004-6361},
  url		= {http://adsabs.harvard.edu/abs/1998A%26A...334..505P},
  abstract	= {New detailed stellar yields of several elemental species
		  are derived for massive stars in a wide range of masses
		  (from 6 to 120 Msun) and metallicities (Z =0.0004, 0.004,
		  0.008, 0.02, 0.05). Our calculations are based on the
		  Padova evolutionary tracks and take into account recent
		  results on stellar evolution, such as overshooting and
		  quiescent mass-loss, paying major attention to the effects
		  of the initial chemical composition of the star. We finally
		  include modern results on explosive nucleosynthesis in
		  SN{\textbackslash}ae{\textbackslash} by Woosley \& Weaver
		  (1995). The issue of the chemical yields of Very Massive
		  Objects (from 120 to 1000 Msun) is also addressed. Our grid
		  of stellar yields for massive stars is complementary to the
		  results by Marigo \{\vphantom{\}}et al. (1996, 1998) on the
		  evolution and nucleosynthesis of low and intermediate mass
		  stars, also based on the Padova evolutionary tracks.
		  Altogether, they represent a complete set of stellar yields
		  of unprecedented homogeneity and self-consistency. Our new
		  stellar yields are inserted in a code for the chemical
		  evolution of the Galactic disc with infall of primordial
		  gas, according to the formulation first suggested by Talbot
		  \& Arnett (1971, 1973, 1975) and Chiosi (1980). As a first
		  application, the code is used to develop a model of the
		  chemical evolution of the Solar Vicinity, with a detailed
		  comparison to the available observational constraints.},
  urldate	= {2013-09-03},
  journal	= {Astronomy and Astrophysics},
  author	= {Portinari, L. and Chiosi, C. and Bressan, A.},
  month		= jun,
  year		= {1998},
  keywords	= {Abundances, Nuclear Reactions, Nucleosynthesis, SOLAR
		  NEIGHBOURHOOD, Galaxy: abundances, SUPERNOVAE: GENERAL,
		  STARS: MASS LOSS, Galaxy: evolution},
  pages		= {505--539}
}

@Article{	  poulton_extracting_2021,
  title		= {Extracting galaxy merger time-scales {II}: a new fitting
		  formula},
  volume	= {501},
  issn		= {0035-8711},
  shorttitle	= {Extracting galaxy merger time-scales {II}},
  url		= {https://ui.adsabs.harvard.edu/abs/2021MNRAS.501.2810P/abstract},
  doi		= {10.1093/mnras/staa3247},
  abstract	= {Predicting the merger time-scale
		  (τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater})
		  of merging dark matter haloes, based on their orbital
		  parameters and the structural properties of their hosts, is
		  a fundamental problem in gravitational dynamics that has
		  important consequences for our understanding of
		  cosmological structure formation and galaxy formation.
		  Previous models predicting
		  τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater}
		  have shown varying degrees of success when compared to the
		  results of cosmological N-body simulations. We build on
		  this previous work and propose a new model for
		  τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater}
		  that draws on insights derived from these simulations. We
		  find that published predictions can provide reasonable
		  estimates for
		  τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater}
		  based on orbital properties at infall, but tend to
		  underpredict
		  τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater}
		  inside the host virial radius
		  (R{\textless}SUB{\textgreater}200{\textless}/SUB{\textgreater})
		  because tidal stripping is neglected, and overpredict it
		  outside
		  R{\textless}SUB{\textgreater}200{\textless}/SUB{\textgreater}
		  because the host mass is underestimated. Furthermore, we
		  find that models that account for orbital angular momentum
		  via the circular radius
		  R{\textless}SUB{\textgreater}circ{\textless}/SUB{\textgreater}
		  underpredict (overpredict)
		  τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater}
		  for bound (unbound) systems. By fitting for the dependence
		  of
		  τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater}
		  on various orbital and host halo properties, we derive an
		  improved model for
		  τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater}
		  that can be applied to a merging halo at any point in its
		  orbit. Finally, we discuss briefly the implications of our
		  new model for
		  τ{\textless}SUB{\textgreater}merge{\textless}/SUB{\textgreater}
		  for semi-analytical galaxy formation modelling.},
  language	= {en},
  number	= {2},
  urldate	= {2026-03-30},
  journal	= {Monthly Notices of the Royal Astronomical Society},
  author	= {Poulton, R. J. J. and Power, C. and Robotham, A. S. G. and
		  Elahi, P. J. and Lagos, C. D. P.},
  month		= feb,
  year		= {2021},
  pages		= {2810--2820}
}

