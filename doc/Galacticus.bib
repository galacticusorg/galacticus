@Article{	  kaur_stalling_2018,
  title		= {Stalling of {Globular} {Cluster} {Orbits} in {Dwarf}
		  {Galaxies}},
  volume	= {868},
  url		= {http://adsabs.harvard.edu/abs/2018ApJ...868..134K},
  doi		= {10.3847/1538-4357/aaeacf},
  abstract	= {We apply the Tremaine-Weinberg theory of dynamical
		  friction to compute the orbital decay of a globular cluster
		  (GC) on an initially circular orbit inside a cored
		  spherical galaxy with isotropic stellar velocities. The
		  retarding torque on the GC, \{\vphantom{\}}
		  {\textbackslash}mathcal T
		  \vphantom{\{}\}(\{r\}\{\{p\}\}){\textless} 0, is a function
		  of its orbital radius \{r\}\{\{p\}\}. The torque is exerted
		  by stars whose orbits are resonant with the GC’s orbit
		  and given as a sum over the infinitely many possible
		  resonances by the Lynden-Bell-Kalnajs (LBK) formula. We
		  calculate the LBK torque \{\vphantom{\}}
		  {\textbackslash}mathcal T \vphantom{\{}\}(\{r\}\{\{p\}\})
		  and determine \{r\}\{\{p\}\}(t) for a GC of mass
		  \{M\}\{\{p\}\}=2× \{10\}5 \{M\}⊙ and an isochrone galaxy
		  of core mass \{M\}\{\{c\}\}=4× \{10\}8 \{M\}⊙ and core
		  radius b=1000 \{pc\}. (i) When \{r\}\{\{p\}\}≳ 300
		  \{pc\}, many strong resonances are active, and as expected,
		  \{ {\textbackslash}mathcal T \}≈
		  \{\vphantom{\}}\{\vphantom{\}} {\textbackslash}mathcal T
		  \vphantom{\{}\}\vphantom{\{}\}\{\{C\}\}, the classical
		  Chandrasekhar torque. (ii) For \{r\}\{\{p\}\}{\textless}
		  300 \{pc\}, \{ {\textbackslash}mathcal T \} comes mostly
		  from stars nearly corotating with the GC, trailing or
		  leading it slightly; trailing resonances exert stronger
		  torques. (iii) As \{r\}\{\{p\}\} decreases, the number and
		  strength of resonances drop, so {\textbar} \{
		  {\textbackslash}mathcal T \} {\textbar} also decreases,
		  with {\textbar} \{ {\textbackslash}mathcal T \} {\textbar}
		  {\textless} \{10\}-2 {\textbar} \{\{
		  {\textbackslash}mathcal T \}\}\{\{C\}\} {\textbar} at
		  \{r\}\{\{p\}\}=\{r\}* ≃
		  \{(\{M\}\{\{p\}\}/\{M\}\{\{c\}\})\}1/5 b≃ 220 \{pc\}, a
		  characteristic “filtering” radius. (iv) Many resonances
		  cease to exist inside \{r\}* ; this includes all leading
		  and low-order trailing ones. (v) The higher-order trailing
		  resonances inside \{r\}* are very weak, with {\textbar} \{
		  {\textbackslash}mathcal T \} {\textbar} {\textless}
		  \{10\}-4 {\textbar} \{\{ {\textbackslash}mathcal T \}\}\{\{C\}\} {\textbar} at \{r\}\{\{p\}\}=150 \{pc\}. (vi) Inspiral times for \{r\}\{\{p\}\}(t) to decay from 300 \{pc\} to \{r\}* far exceed 10 \{Gyr\}.},
  urldate	= {2020-09-15},
  journal	= {The Astrophysical Journal},
  author	= {Kaur, Karamveer and Sridhar, S.},
  month		= dec,
  year		= {2018},
  keywords	= {galaxies: dwarf, galaxies: kinematics and dynamics},
  pages		= {134}
}

@Article{	  kazantzidis_2006,
  author	= {Stelios Kazantzidis and Andrew R. Zentner and Andrey V.
		  Kravtsov},
  title		= {The Robustness of Dark Matter Density Profiles in
		  Dissipationless Mergers},
  journal	= {The Astrophysical Journal},
  volume	= {641},
  number	= {2},
  pages		= {647},
  url		= {http://stacks.iop.org/0004-637X/641/i=2/a=647},
  doi		= {10.1086/500579},
  eprint	= {astro-ph/0510583},
  archiveprefix	= {arXiv},
  primaryclass	= {astro-ph},
  year		= {2006},
  abstract	= {We present a comprehensive series of dissipationless N
		  -body simulations to investigate the evolution of density
		  distribution in equal-mass mergers between dark matter (DM)
		  halos and multicomponent galaxies. The DM halo models are
		  constructed with various asymptotic power-law indices
		  ranging from steep cusps to corelike profiles and the
		  structural properties of the galaxy models are motivated by
		  the ΛCDM paradigm of structure formation. The adopted
		  force resolution allows robust density profile estimates in
		  the inner ~1% of the virial radii of the simulated systems.
		  We demonstrate that the central slopes and overall shapes
		  of the remnant density profiles are virtually identical to
		  those of the initial systems, suggesting that the remnants
		  retain a remarkable memory of the density structure of
		  their progenitors, despite the relaxation that accompanies
		  merger activity. We also find that halo concentrations
		  remain approximately constant through hierarchical merging
		  involving identical systems and show that remnants contain
		  significant fractions of their bound mass well beyond their
		  formal virial radii. These conclusions hold for a wide
		  variety of initial asymptotic density slopes, orbital
		  energies, and encounter configurations, including sequences
		  of consecutive merger events, simultaneous mergers of
		  several systems, and mergers of halos with embedded cold
		  baryonic components in the form of disks, spheroids, or
		  both. As an immediate consequence, the net effect of gas
		  cooling, which contracts and steepens the inner density
		  profiles of DM halos, should be preserved through a period
		  of dissipationless major merging. Our results imply that
		  the characteristic universal shape of DM density profiles
		  may be set early in the evolution of halos.}
}

@Article{	  kelvin_galaxy_2014,
  title		= {Galaxy {And} {Mass} {Assembly} ({GAMA}): {ugrizYJHK}
