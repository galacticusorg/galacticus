@Article{	  gnedin_self-consistent_1999,
  title		= {On the {Self}-consistent {Response} of {Stellar} {Systems}
		  to {Gravitational} {Shocks}},
  volume	= {513},
  issn		= {0004-637X},
  url		= {http://adsabs.harvard.edu/abs/1999ApJ...513..626G},
  doi		= {10.1086/306864},
  abstract	= {We study the reaction of a globular star cluster to a
		  time-varying tidal perturbation (gravitational shock) using
		  self-consistent N-body simulations and address two
		  questions. First, to what extent is the cluster interior
		  protected by adiabatic invariants? Second, how much further
		  energy change does the postshock evolution of the cluster
		  potential produce and how much does it affect the
		  dispersion of stellar energies? We introduce the
		  ``adiabatic correction'' as ratio of the energy change,
		  {\textless}ΔE{\textgreater}, to its value in the impulse
		  approximation. When the potential is kept fixed, the
		  numerical results for the adiabatic correction for stars
		  with orbital frequency ω can be approximated as
		  (1+ω2τ2)-γ. For shocks with the characteristic duration
		  of the order of the half-mass dynamical time of the
		  cluster, τ{\textless}{\textasciitilde}tdyn,h, the exponent
		  γ=5/2. For more prolonged shocks,
		  τ{\textgreater}{\textasciitilde}4tdyn,h, the adiabatic
		  correction is shallower, γ=3/2. When we allow for
		  self-gravity and potential oscillations that follow the
		  shock, the energy of stars in the core changes
		  significantly while the total energy of the system is
		  conserved. Paradoxically, the postshock potential
		  fluctuations reduce the total amount of energy dispersion,
		  {\textless}ΔE2{\textgreater}. The effect is small but real
		  and is due to the postshock energy change being
		  statistically anticorrelated with the shock-induced
		  heating. These results are to be applied to Fokker-Planck
		  models of the evolution of globular clusters.},
  urldate	= {2021-02-03},
  journal	= {The Astrophysical Journal},
  author	= {Gnedin, Oleg Y. and Ostriker, Jeremiah P.},
  month		= mar,
  year		= {1999},
  keywords	= {Celestial Mechanics, CELESTIAL MECHANICS, globular
		  clusters: general, GLOBULAR CLUSTERS: GENERAL, methods:
		  numerical, METHODS: NUMERICAL, Stellar Dynamics, STELLAR
		  DYNAMICS},
