@Article{	  cole_biased_1989,
  title		= {Biased clustering in the cold dark matter cosmogony},
  volume	= {237},
  issn		= {0035-8711},
  url		= {http://adsabs.harvard.edu/abs/1989MNRAS.237.1127C},
  doi		= {10.1093/mnras/237.4.1127},
  abstract	= {The Press-Schechter (1974) approximation is used to
		  determine the abundance and large-scale clustering of dark
		  haloes in the cold dark matter cosmogony. It is found that
		  there exists a wide range of haloes which are both
		  sufficiently massive and sufficiently numerous to host
		  quasars, and that if the diffuse X-ray background is
		  generated by discrete sources associated with dark haloes,
		  then the halo masses are constrained to be less than 10 to
		  the 12th/h solar masses. Two simple models for galaxy
		  formation are considered.},
