@Article{	  sutherland_accurate_1998,
  title		= {Accurate free-free Gaunt factors for astrophysical
		  plasmas},
  volume	= {300},
  issn		= {0035-8711},
  url		= {http://adsabs.harvard.edu/abs/1998MNRAS.300..321S},
  doi		= {10.1046/j.1365-8711.1998.01687.x},
  abstract	= {New calculations of free-free transition matrix element
		  integrals are performed using modern symbolic computing
		  techniques to evaluate the hypergeometric functions with
		  complex arguments. The results are presented in both
		  graphical and tabular form including accurate extrapolation
		  methods. The results are accurate to the level of
		  {\textasciitilde}10{\textasciicircum}-4, beyond which
		  relativistic corrections would be needed, which are not
		  included. The results are also computed over a very wide
		  range of scaled ionic temperature
		  (gamma{\textasciicircum}2) and wavelength, extending
		  earlier results to new regimes encountered in highly
		  photoionized and non-equilibrium ionization plasmas. These
		  results will be useful in the spectral range from
		  submillimetre to hard X-ray wavelengths and temperatures
		  from 10 to 10{\textasciicircum}9 K.},
  urldate	= {2014-10-01},
  journal	= {Monthly Notices of the Royal Astronomical Society},
  author	= {Sutherland, Ralph S.},
  month		= oct,
  year		= {1998},
  keywords	= {{ATOMIC} {DATA}, {ATOMIC} {PROCESSES}, {ISM}: {GENERAL},
		  {PLASMAS}, {RADIATION} {MECHANISMS}: {THERMAL}},
  pages		= {321--330}
}

@Article{	  takahashi_full-sky_2017,
  title		= {Full-sky {Gravitational} {Lensing} {Simulation} for
		  {Large}-area {Galaxy} {Surveys} and {Cosmic} {Microwave}
		  {Background} {Experiments}},
  volume	= {850},
  issn		= {0004-637X},
  url		= {https://ui.adsabs.harvard.edu/abs/2017ApJ...850...24T},
  doi		= {10.3847/1538-4357/aa943d},
  abstract	= {We present 108 full-sky gravitational lensing simulation
		  data sets generated by performing multiple-lens plane
		  ray-tracing through high-resolution cosmological N-body
		  simulations. The data sets include full-sky convergence and
		  shear maps from redshifts z = 0.05 to 5.3 at intervals of
		  150 \{h\}-1\{Mpc\} comoving radial distance (corresponding
		  to a redshift interval of \{\{∆ \}\}z≃ 0.05 at the
		  nearby universe), enabling the construction of a mock shear
		  catalog for an arbitrary source distribution up to z = 5.3.
		  The dark matter halos are identified from the same N-body
		  simulations with enough mass resolution to resolve the host
		  halos of the Sloan Digital Sky Survey (SDSS) CMASS and
		  luminous red galaxies (LRGs). Angular positions and
		  redshifts of the halos are provided by a ray-tracing
		  calculation, enabling the creation of a mock halo catalog
		  to be used for galaxy-galaxy and cluster-galaxy lensing.
		  The simulation also yields maps of gravitational lensing
		  deflections for a source redshift at the last scattering
		  surface, and we provide 108 realizations of lensed cosmic
		  microwave background (CMB) maps in which the post-Born
		  corrections caused by multiple light scattering are
		  included. We present basic statistics of the simulation
		  data, including the angular power spectra of cosmic shear,
		  CMB temperature and polarization anisotropies,
		  galaxy-galaxy lensing signals for halos, and their
		  covariances. The angular power spectra of the cosmic shear
		  and CMB anisotropies agree with theoretical predictions
		  within 5\% up to \{{\textbackslash}ell \}=3000 (or at an
		  angular scale θ {\textgreater} 0.5 arcmin). The simulation
		  data sets are generated primarily for the ongoing Subaru
		  Hyper Suprime-Cam survey, but are freely available for
		  download at
		  http://cosmo.phys.hirosaki-u.ac.jp/takahasi/allsky\_raytracing/.},
  urldate	= {2026-05-11},
  journal	= {The Astrophysical Journal},
  publisher	= {IOP},
  author	= {Takahashi, Ryuichi and Hamana, Takashi and Shirasaki,
		  Masato and Namikawa, Toshiya and Nishimichi, Takahiro and
		  Osato, Ken and Shiroyama, Kosei},
  month		= nov,
  year		= {2017},
  note		= {ADS Bibcode: 2017ApJ...850...24T},
  keywords	= {Astrophysics - Cosmology and Nongalactic Astrophysics,
		  cosmic background radiation, General Relativity and Quantum
		  Cosmology, gravitational lensing: weak, large-scale
		  structure of universe},
  pages		= {24}
}

