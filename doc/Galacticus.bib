@Article{	  covington_effects_2011,
  title		= {The Effects of Dissipation on {Early-Type} Scaling
		  Relations in {Semi-Analytic} Models},
  volume	= {in preparation},
  abstract	= {Observed elliptical galaxies follow a number of scaling
		  relations between stellar mass, velocity dispersion, and
		  size. Furthermore, they fall in a tight plane called the
		  ”fun- damental plane” in this three-dimensional space.
		  If major merging of disk galaxies is a viable mechanism for
		  the production of elliptical galaxies, then merging must be
		  capable of producing these scaling relations. Previous
		  studies have suggested that it is diﬃcult to produce the
		  observed slope and scatter of the early-type size-mass
		  relation via major mergers. We apply a simple theoretical
		  merger model to galaxy progenitors produced by two
		  semi-analytical models, in order to derive scaling
		  relations of merger remnants. Importantly, our model
		  includes the eﬀects of gaseous energy dissipation and
		  star formation. Using this model, and without tuning the
		  parameters to each {SAM,} we are able to roughly match the
		  slope and scatter in the observed scaling rela- tions at
		  low redshift as well as the observed amount of evolution of
		  the relations since redshift z = 3. Within this model, the
		  production of the observed scaling relations, including the
		  tilt in the fundamental plane, results from the decrease in
		  spiral galaxy progenitor gas fractions with increasing
		  mass.},
  journal	= {{MNRAS}},
  author	= {M. Covington and J. R. Primack and Lauren Porter and
		  Darren Croton and R. S. Somerville and Avishai Dekel},
  year		= {2011}
}

