@Article{	  zhao_analytical_1996,
  title		= {Analytical models for galactic nuclei},
  volume	= {278},
  issn		= {0035-8711},
  url		= {https://doi.org/10.1093/mnras/278.2.488},
  doi		= {10.1093/mnras/278.2.488},
  abstract	= {I present a general family of dynamical models with simple
		  analytical potential-density pairs suited to modelling
		  galactic bulges and nuclei with double power-law radial
		  density profiles and an optional central black hole.
		  Analytical expressions for the potential and velocity
		  dispersion of these models are given for the spherical
		  case. Many previously known analytical spherical models,
		  including the recent γ/η-models by Dehnen and Tremaine et
		  al., are special cases of this family. The family also
		  forms a complete set for constructing general galaxy models
		  or solving Poisson's equation in the non-spherical case. In
		  particular, a generalized Clutton-Brock and
		  Hernquist-Ostriker orthogonal basis set is given.},
