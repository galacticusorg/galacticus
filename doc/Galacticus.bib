@Article{	  trac_scorch_2015,
  title		= {{SCORCH} {I}: {The} {Galaxy}-{Halo} {Connection} in the
		  {First} {Billion} {Years}},
  volume	= {813},
  issn		= {0004-637X},
  shorttitle	= {{SCORCH} {I}},
  url		= {http://adsabs.harvard.edu/abs/2015ApJ...813...54T},
  doi		= {10.1088/0004-637X/813/1/54},
  abstract	= {SCORCH (Simulations and Constructions of the Reionization
		  of Cosmic Hydrogen) is a new project to study the Epoch of
		  Reionization (EoR). In this first paper, we probe the
		  connection between observed high-redshift galaxies and
		  simulated dark matter halos to better understand the
		  primary source of ionizing radiation. High-resolution
		  N-body simulations are run to quantify the abundance of
		  dark matter halos as a function of mass M, accretion rate
		  {\textbackslash}dot\{M\}, and redshift z. A new fit for the
		  halo mass function dn/dM is ≈20\% more accurate at the
		  high-mass end. A novel approach is used to fit the halo
		  accretion rate function \{dn\}/d{\textbackslash}dot\{M\} in
		  terms of the halo mass function. Abundance matching against
		  the observed galaxy luminosity function is used to estimate
		  the luminosity-mass relation and the
		  luminosity-accretion-rate relation. The inferred star
		  formation efficiency is not monotonic with M nor
		  {\textbackslash}dot\{M\}, but reaches a maximum value at a
		  characteristic mass ˜ 2× \{10\}11 \{M\}⊙ and a
		  characteristic accretion rate ˜ 6× \{10\}2 \{M\}⊙
		  \{\{\{yr\}\}\}-1 at z ≈ 6. We find a universal EoR
		  luminosity-accretion-rate relation and construct a fiducial
		  model for the galaxy luminosity function. The Schechter
		  parameters evolve such that \{φ \}{\textbackslash}star
		  decreases, \{M\}{\textbackslash}star is fainter, and α is
		  steeper at higher redshifts. We forecast for the upcoming
		  James Webb Space Telescope and show that with apparent
		  magnitude limit \{m\}\{\{AB\}\}≈ 31 (32), it can observe
		  ≳ 11 (24) unlensed galaxies per square degree per unit
		  redshift at least down to \{M\}{\textbackslash}star at z ≲ 13 (14).},
  urldate	= {2018-06-28},
  journal	= {The Astrophysical Journal},
  author	= {Trac, Hy and Cen, Renyue and Mansfield, Philip},
  month		= nov,
  year		= {2015},
  keywords	= {cosmology: theory, dark ages, first stars, galaxies:
		  high-redshift, large-scale structure of universe, methods:
		  numerical, reionization},
  pages		= {54}
}

@Article{	  trenti_how_2010,
  title		= {How {Well} do {Cosmological} {Simulations} {Reproduce}
		  {Individual} {Halo} {Properties}?},
  volume	= {711},
  issn		= {0004-637X},
  url		= {http://adsabs.harvard.edu/abs/2010ApJ...711.1198T},
  doi		= {10.1088/0004-637X/711/2/1198},
  abstract	= {Cosmological simulations of galaxy formation often rely on
		  prescriptions for star formation and feedback that depend
		  on halo properties such as halo mass, central overdensity,
		  and virial temperature. In this paper, we address the
		  convergence of individual halo properties, based on their
		  number of particles N, focusing, in particular, on the mass
		  of halos near the resolution limit of a simulation. While
		  it has been established that the halo mass function is
		  sampled on average down to N {\textasciitilde} 20-30
		  particles, we show that individual halo properties exhibit
		  significant scatter, and some systematic biases, as one
		  approaches the resolution limit. We carry out a series of
		  cosmological simulations using the Gadget2 and Enzo codes
		  with Np = 643 to Np = 10243 total particles, keeping the
		  same large-scale structure in the simulation box. We
		  consider boxes of small (l box = 8 Mpc h -1), medium (l box
		  = 64 Mpc h -1), and large (l box = 512 Mpc h -1) size to
		  probe different halo masses and formation redshifts. We
		  cross-identify dark matter halos in boxes at different
		  resolutions and measure the scatter in their properties.
		  The uncertainty in the mass of single halos depends on the
		  number of particles (scaling approximately as N -1/3), but
		  the rarer the density peak, the more robust its
		  identification. The virial radius of halos is very stable
		  and can be measured without bias for halos with N
		  {\textgreater}{\textasciitilde} 30. In contrast, the
		  average density within a sphere containing 25\% of the
		  total halo mass is severely underestimated (by more than a
		  factor 2) and the halo spin is moderately overestimated for
		  N {\textless}{\textasciitilde} 100. If sub-grid physics is
		  implemented upon a cosmological simulation, we recommend
		  that rare halos ({\textasciitilde}3σ peaks) be resolved
		  with N {\textgreater}{\textasciitilde} 100 particles and
		  common halos ({\textasciitilde}1σ peaks) with N
		  {\textgreater}{\textasciitilde} 400 particles to avoid
		  excessive numerical noise and possible systematic biases in
		  the results.},
  urldate	= {2017-03-21},
  journal	= {The Astrophysical Journal},
  author	= {Trenti, Michele and Smith, Britton D. and Hallman, Eric J.
		  and Skillman, Samuel W. and Shull, J. Michael},
  month		= mar,
  year		= {2010},
  keywords	= {galaxies: formation, methods: numerical},
  pages		= {1198--1207}
}

@Article{	  ucci_astraeus_2023,
  title		= {Astraeus {V}: the emergence and evolution of metallicity
		  scaling relations during the epoch of reionization},
  volume	= {518},
  issn		= {0035-8711},
  shorttitle	= {Astraeus {V}},
  url		= {https://ui.adsabs.harvard.edu/abs/2023MNRAS.518.3557U},
  doi		= {10.1093/mnras/stac2654},
  abstract	= {In this work, we have implemented a detailed physical
		  model of galaxy chemical enrichment into the ASTRAEUS
		  (seminumerical rAdiative tranSfer coupling of galaxy
		  formaTion and Reionization in N-body dark matter
		  simUlationS) framework which couples galaxy formation and
		  reionization in the first billion years. Simulating
		  galaxies spanning over 2.5 orders of magnitude in halo mass
		  with \$M\_\{{\textbackslash}rm h\} {\textbackslash}sim
		  10{\textasciicircum}\{8.9\}\{-\}10{\textasciicircum}\{11.5\}{\textbackslash},\{{\textbackslash}rm
		  M\_{\textbackslash}odot\}\$ (\$M\_\{{\textbackslash}rm h\}
		  {\textbackslash}sim
		  10{\textasciicircum}\{8.9\}\{-\}10{\textasciicircum}\{12.8\}{\textbackslash}rm
		  M\_{\textbackslash}odot\$) at z {\textasciitilde} 10 (5),
		  we find: (i) smooth accretion of metal-poor gas from the
		  intergalactic medium (IGM) plays a key role in diluting the
		  interstellar medium interstellar medium metallicity which
		  is effectively restored due to self-enrichment from star
		  formation; (ii) a redshift averaged gas-mass loading factor
