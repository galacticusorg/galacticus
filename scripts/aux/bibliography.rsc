% Resource file for tidying doc/Galacticus.bib via bibtool.
% Used by the bibliographyUpdater workflow after the ADS update step.

% Sort entries alphabetically by their citation key.
sort = on

% Preserve the case of citation keys exactly (we never want bibtool to rewrite
% the keys our documentation cites).
preserve.key.case = on

% Drop duplicate entries (same citation key) without prompting.
check.double = on
check.double.delete = on
